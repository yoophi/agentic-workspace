{
  "name": "agentic-workbench",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "dev": "turbo run dev --filter=@yoophi/agentic-workbench",
    "dev:workbench": "turbo run dev --filter=@yoophi/agentic-workbench",
    "dev:annotator": "turbo run dev --filter=@yoophi/markdown-annotator",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "preview": "turbo run preview --filter=@yoophi/agentic-workbench",
    "preview:workbench": "turbo run preview --filter=@yoophi/agentic-workbench",
    "preview:annotator": "turbo run preview --filter=@yoophi/markdown-annotator",
    "storybook:annotator": "turbo run storybook --filter=@yoophi/markdown-annotator",
    "build-storybook:annotator": "turbo run build-storybook --filter=@yoophi/markdown-annotator",
    "tauri": "turbo run tauri --filter=@yoophi/agentic-workbench --",
    "tauri:workbench": "turbo run tauri --filter=@yoophi/agentic-workbench --",
    "tauri:annotator": "turbo run tauri --filter=@yoophi/markdown-annotator --",
    "tauri:dev": "turbo run tauri:dev --filter=@yoophi/agentic-workbench --",
    "tauri:dev:workbench": "turbo run tauri:dev --filter=@yoophi/agentic-workbench --",
    "tauri:dev:annotator": "turbo run tauri:dev --filter=@yoophi/markdown-annotator --"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
